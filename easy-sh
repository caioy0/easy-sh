#!/bin/bash

distro=""
skip_dotfiles=false

install_omz() {
    if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
        printf "[~] Installing Oh My Zsh...\n"
        printf "n" | RUNZSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)\n"
    fi
}

install_zsh_plugins() {
    ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
    clone_if_not_exists "https://github.com/zsh-users/zsh-autosuggestions" "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
    clone_if_not_exists "https://github.com/zsh-users/zsh-syntax-highlighting.git" "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
    clone_if_not_exists "https://github.com/unixorn/fzf-zsh-plugin.git" "$ZSH_CUSTOM/plugins/fzf-zsh-plugin"
    clone_if_not_exists "https://github.com/zdharma-continuum/fast-syntax-highlighting.git" "$ZSH_CUSTOM/plugins/fast-syntax-highlighting"
    clone_if_not_exists "https://github.com/romkatv/powerlevel10k.git" "$ZSH_CUSTOM/themes/powerlevel10k"
}

clone_if_not_exists() {
    local repo=$1
    local target=$2
    if [[ ! -d "$target" ]]; then
        git clone --depth=1 "$repo" "$target"
    else
        printf "[~] Already exists: $target\n"
    fi
}

safe_link() {
    local src="$1"
    local dest="$2"
    src="${src%/}"
    dest="${dest%/}"

    if [[ ! -e "$src" ]]; then
        printf "[!] Source not found: %s\n" "$src"
        return 1
    fi

    if [[ -L "$dest" ]]; then
        local current_target
        current_target=$(readlink "$dest")
        if [[ "$current_target" == "$src" ]]; then
            printf "[=] Already linked: %s → %s\n" "$dest" "$src"
            return 0
        else
            printf "[!] Skipping: %s already links to %s\n" "$dest" "$current_target"
            return 1
        fi
    fi

    mkdir -p "$(dirname "$dest")"
    ln -s "$src" "$dest"
    printf "[✓] Link created: %s → %s\n" "$dest" "$src"
}

backup_file() {
    local target=$1
    local backup=$2
    if [[ -e "$target" ]]; then
        cp -r "$target" "$backup"
        printf "[✓] Backup created: $backup\n"
    fi
}

copy_dotfiles(){
    if [[ ! -d "$HOME/dotfiles" ]]; then
        cp -rf "dotfiles/" "$HOME/dotfiles"
    else
        printf "[~] Updating dotfiles...\n"
        cp -rf "dotfiles/" "$HOME"
        [[ ! -d "$HOME/.config" ]] && mkdir -p "$HOME/.config"
    fi
}

show_menu() {
    printf "Setup Menu\n"
    printf "Choose your distro:\n"
    printf "1) Arch - Install Arch base apps\n"
    printf "2) Debian - Install Debian base apps\n"
    printf "3) Fedora - Install Fedora base apps\n"
    printf "4) macOS - Install macOS base apps\n"
    printf "5) None - Dotfiles - shell\n"

    printf "Enter choice [1-5]: "
    read choice

    case $choice in
        1)
            distro="arch"
            bash ./arch-base/apps.sh
            ;;
        2)
            distro="debian"
            bash ./deb-base/apps.sh
            ;;
        3)
            distro="fedora"
            bash ./fed-base/apps.sh
            ;;
        4)
            distro="macos"
            zsh ./macos/apps.sh
            ;;
        5)
            distro="no-distro"
            ;;
        *)
            printf "Invalid option.\n"
            exit 1
            ;;
    esac

    printf "\n"
    printf "Skip dotfiles? [y/N] "
    read confirm

    case $confirm in
        [yY][eE][sS]|[yY])
            skip_dotfiles=false
            ;;
        *)
            skip_dotfiles=true
            ;;
    esac
}

show_wsl_menu() {
    printf "Setup Menu\n"
    printf "Choose your distro:\n"
    printf "1) Arch - Install Arch base apps\n"
    printf "2) Debian - Install Debian base apps\n"
    printf "3) Fedora - Install Fedora base apps\n"

    printf "Enter choice [1-3]: "
    read choice

    case $choice in
        1)
            distro="arch"
            bash ./scripts/arch-install.sh
            ;;
        2)
            distro="debian"
            bash ./scripts/deb-install.sh
            ;;
        3)
            distro="fedora"
            bash ./scripts/fed-install.sh
            ;;
        *)
            printf "Invalid option.\n"
            exit 1
            ;;
    esac
}

show_help() {
    printf "Usage: ./install.sh [options]\n"
    printf "Options:\n"
    printf " -d | --debian\n"
    printf " -a | --arch\n"
    printf " -f | --fedora\n"
    printf " -m | --macos\n"
    printf " -w | --wsl              WSL support\n"
    printf " -l | --hyprland dotfiles\n"
    printf " -b | --only-dotfiles    copy dotfiles only\n"
    printf " --skip-dotfiles         skip dotfiles setup\n"
}

# --- If no arguments, show menu ---
if [ $# -eq 0 ]; then
    if [[ "$(uname)" == "Darwin" ]]; then
        printf "Use --help for more options (macOS detected)\n"
        exit 0
    else
        printf "Use --help for more options\n"
        show_menu
    fi
else
    # argument parsing (kept for compatibility)
    while [ $# -gt 0 ]; do
        case "$1" in 
            -d|--debian) distro="debian"; bash ./deb-base/apps.sh ;;
            -a|--arch) distro="arch"; bash ./arch-base/apps.sh ;;
            -f|--fedora) distro="fedora"; bash ./fed-base/apps.sh ;;
            -m|--macos) distro="macos"; zsh ./macos/apps.sh ;;
            -l|--hyprland) distro="hyprland" ;;
            -w|--wsl) show_wsl_menu; exit 0 ;;
            -b|--only-dotfiles) distro="no-distro" ;;
            --skip-dotfiles) skip_dotfiles=true ;;
            --help|-h) show_help; exit 0 ;;
            *) printf "Unknown argument: $1\n"; exit 1 ;;
        esac
        shift
    done
fi

# oh-my-zsh install 
install_omz
install_zsh_plugins

# Respect skip-dotfiles flag
if [ "$skip_dotfiles" = true ]; then
    printf "⏩ Skipping dotfiles setup...\n"
else
    backup_file "$HOME/.zshrc" "$HOME/.zshrc.bak"
    backup_file "$HOME/.bashrc" "$HOME/.bashrc.bak"
    backup_file "$HOME/.config" "$HOME/.config.bak"

    copy_dotfiles

    safe_link "$HOME/dotfiles/.zshrc" "$HOME/.zshrc"
    safe_link "$HOME/dotfiles/.bashrc" "$HOME/.bashrc"
    safe_link "$HOME/dotfiles/.config/bashrc" "$HOME/.config/bashrc"
    safe_link "$HOME/dotfiles/.config/kitty" "$HOME/.config/kitty"
    safe_link "$HOME/dotfiles/.config/nvim/" "$HOME/.config/nvim"
    safe_link "$HOME/dotfiles/.config/fastfetch/" "$HOME/.config/fastfetch"

    if [[ "$distro" = "hyprland" || "$distro" = "arch" ]]; then
        safe_link "$HOME/dotfiles/.config/hypr/" "$HOME/.config/hypr"
        safe_link "$HOME/dotfiles/.config/waybar/" "$HOME/.config/waybar"
        safe_link "$HOME/dotfiles/.config/waypaper/" "$HOME/.config/waypaper"
        safe_link "$HOME/dotfiles/.config/matugen/" "$HOME/.config/matugen"
    fi
fi

printf "\nThats it ༼ つ ◕_◕ ༽つ \n"
