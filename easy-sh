#!/bin/bash

distro=""
skip_custominstall=false
skip_dotfiles=false

install_omz() {
    if [[ ! -d "$HOME/.oh-my-zsh" ]]; then
        printf "[~] Installing Oh My Zsh...\n"
        echo "n" | RUNZSH=no sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
    fi
}

install_zsh_plugins() {
    ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
    clone_if_not_exists "https://github.com/zsh-users/zsh-autosuggestions" "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
    clone_if_not_exists "https://github.com/zsh-users/zsh-syntax-highlighting.git" "$ZSH_CUSTOM/plugins/zsh-syntax-highlighting"
    clone_if_not_exists "https://github.com/unixorn/fzf-zsh-plugin.git" "$ZSH_CUSTOM/plugins/fzf-zsh-plugin"
    clone_if_not_exists "https://github.com/zdharma-continuum/fast-syntax-highlighting.git" "$ZSH_CUSTOM/plugins/fast-syntax-highlighting"
    clone_if_not_exists "https://github.com/romkatv/powerlevel10k.git" "$ZSH_CUSTOM/themes/powerlevel10k"
}

clone_if_not_exists() {
    local repo=$1
    local target=$2
    if [[ ! -d "$target" ]]; then
        git clone --depth=1 "$repo" "$target"
    else
        echo "[~] Already exists: $target"
    fi
}

safe_link() {
    local src=$1
    local dest=$2

    if [[ -e "$src" ]]; then
        ln -sf "$src" "$dest"
        echo "[✓] Link created: $dest → $src"
    else
        echo "[!] Warning!: File not found to create link: $src"
    fi
}

backup_file() {
    local target=$1
    local backup=$2
    if [[ -e "$target" ]]; then
        cp -r "$target" "$backup"
        echo "[✓] Backup created: $backup"
    fi
}

copy_dotfiles(){
    if [[ ! -d "$HOME/dotfiles" ]]; then
        cp -rf "dotfiles/" "$HOME"
    else
        echo "[~] Updating dotfiles..."
        cp -rf "dotfiles/" "$HOME"
        [[ ! -d "$HOME/.config" ]] && mkdir -p "$HOME/.config"
    fi
}

show_menu() {
    distro_choice=$(whiptail --title "Setup Menu" \
        --menu "Choose your distro:" 15 50 5 \
        "Arch" "Install Arch base apps" \
        "Debian" "Install Debian base apps" \
        "Fedora" "Install Fedora base apps" \
        "macOS" "Install macOS base apps" \
        "None" "Dotfiles -  shell" \
        3>&1 1>&2 2>&3)

    exitstatus=$?
    if [ $exitstatus = 0 ]; then
        case $distro_choice in
            "Arch") distro="arch"; bash ./arch-base/apps.sh ;;
            "Debian") distro="debian"; bash ./deb-base/apps.sh ;;
            "Fedora") distro="fedora"; bash ./fed-base/apps.sh ;;
            "macOS") distro="macos"; bash ./macos/apps.sh ;;
            "None") distro="no-distro" ;;
        esac
    else
        echo "Cancelled."
        exit 1
    fi

    if whiptail --title "Dotfiles" --yesno "Do you want to set up dotfiles?" 8 40; then
        skip_dotfiles=false
    else
        skip_dotfiles=true
    fi

}


show_help() {
    echo "Usage: ./install.sh [options]"
    echo "Options:"
    echo " -d | --debian"
    echo " -a | --arch"
    echo " -f | --fedora"
    echo " -m | --macos"
    echo " -w | --wsl              WSL support"
    echo " -b | --only-dotfiles    copy dotfiles only"
    echo " --skip-dotfiles         skip dotfiles setup"
}

# --- If no arguments, show menu ---
if [ $# -eq 0 ]; then
    if [[ "$(uname)" == "Darwin" ]]; then
        echo "Use --help for more options (macOS detected)"
        exit 0
    else
        echo "Use --help for more options"
        show_menu
    fi
else
    # argument parsing (kept for compatibility)
    while [ $# -gt 0 ]; do
        case "$1" in 
            -d|--debian) distro="debian"; bash ./deb-base/apps.sh ;;
            -a|--arch) distro="arch"; bash ./arch-base/apps.sh ;;
            -f|--fedora) distro="fedora"; bash ./fed-base/apps.sh ;;
            -m|--macos) distro="macos"; bash ./macos/apps.sh ;;
            -b|--only-dotfiles) distro="no-distro" ;;
            --skip-dotfiles) skip_dotfiles=true ;;
            --skip-custominstall) skip_custominstall=true ;;
            --help|-h) echo "Run without arguments to open interactive menu."; exit 0 ;;
            *) echo "Unknown argument: $1"; exit 1 ;;
        esac
        shift
    done
fi

# oh-my-zsh install 
install_omz
install_zsh_plugins

# Respect skip-dotfiles flag
if [ "$skip_dotfiles" = true ]; then
    echo "⏩ Skipping dotfiles setup..."
else
    backup_file "$HOME/.zshrc" "$HOME/.zshrc.bak"
    backup_file "$HOME/.bashrc" "$HOME/.config.bashrc"
    backup_file "$HOME/.config" "$HOME/.config.bak"

    copy_dotfiles

    safe_link "$HOME/dotfiles/.zshrc" "$HOME/.zshrc"
    safe_link "$HOME/dotfiles/.bashrc" "$HOME/.bashrc"
    safe_link "$HOME/dotfiles/.config/bashrc" "$HOME/.config/bashrc"
    safe_link "$HOME/dotfiles/.config/kitty" "$HOME/.config/kitty"
    safe_link "$HOME/dotfiles/.config/nvim/" "$HOME/.config/nvim"
    safe_link "$HOME/dotfiles/.config/fastfetch/" "$HOME/.config/fastfetch"

    if [ "$distro" = "arch" ]; then
        safe_link "$HOME/dotfiles/.config/hypr/" "$HOME/.config/hypr"
        safe_link "$HOME/dotfiles/.config/waybar/" "$HOME/.config/waybar"
        safe_link "$HOME/dotfiles/.config/waypaper/" "$HOME/.config/waypaper"
        safe_link "$HOME/dotfiles/.config/matugen/" "$HOME/.config/matugen"
    fi
fi


printf "\nThats it ༼ つ ◕_◕ ༽つ \n"
